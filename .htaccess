<IfModule mod_rewrite.c>
  RewriteEngine On

  # Instagram Einstiegspunkt /portfolio → Startseite
  RewriteRule ^portfolio/?$ https://www.danielluzius.de/ [R=302,L]

  # Tracking-Parameter entfernen (utm, fbclid, igshid)
  RewriteCond %{QUERY_STRING} (utm_|fbclid|igshid) [NC]
  RewriteRule ^ %{REQUEST_URI}? [R=301,L]

  # If an existing asset or directory is requested go to it as it is
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
  RewriteRule ^ - [L]

  # SPA Fallback
  RewriteRule ^ /index.html [L]
</IfModule>